# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local state
.claude/

# SQLite — the built DB is bundled (so Vercel deploys can read it without
# rebuilding from the 33 MB of source CSVs). Refresh with `npm run seed`
# locally after pulling new CSVs into data/seed/.
# data/app.db is intentionally NOT ignored.
data/app.db-journal
data/app.db-shm
data/app.db-wal
data/seed/rentstab.csv
data/seed/rentstab_v2.csv

# Editors
.vscode/
.idea/
*.swp
